# Copy to .env and fill in. NEVER commit .env (it's gitignored).

# Required for live AI-visibility (tools/check_ai_visibility.py).
# Get one at https://docs.perplexity.ai/  (pay-as-you-go; sonar is cheap).
PERPLEXITY_API_KEY=

# Optional — raises the PageSpeed Insights rate limit (tools/pagespeed.py).
# https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# Optional — Firecrawl fallback fetcher for tools/audit_site.py. When set, pages
# that plain requests can't read (WAF-blocked 403/202/5xx, or JS-only shells) are
# retried through Firecrawl's proxy/render so they can still be audited. Unset =>
# audit_site uses plain requests only (the --firecrawl flag becomes a no-op).
# Pay-as-you-go; https://www.firecrawl.dev/
FIRECRAWL_API_KEY=

# Optional, for future enrichment tools (not yet wired):
#   Verifiable GBP review counts/ratings -> Google Places API
GOOGLE_PLACES_API_KEY=
#   Backlinks / domain authority / SERP -> DataForSEO (pay-per-call)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Required for the follow-up-complaint classifier (tools/gbp_classify.py, review-scan step 4).
# Pay-as-you-go; Claude Haiku is cheap. https://console.anthropic.com/
ANTHROPIC_API_KEY=
